# ============================================
# 访谈智能整理与分析系统 — 环境变量配置
# ============================================
# 使用方式：
#   1. 复制此文件为 .env： cp .env.example .env
#   2. 填入你的真实密钥
#   3. 或在 Streamlit Cloud Dashboard 设置 Secrets
#
# Streamlit Cloud Secrets 格式（st.secrets）：
#   LLM_API_KEY = "sk-xxx"
#   ALIYUN_AK = "LTAIxxx"
#   ALIYUN_SK = "xxx"
#   DASHSCOPE_API_KEY = "sk-xxx"
# ============================================

# ----- LLM 配置 -----
# DeepSeek / OpenAI 兼容 API 密钥
LLM_API_KEY=""

# ----- 阿里云 ASR 配置 -----
# 阿里云 AccessKey ID（用于 OSS 上传）
ALIYUN_AK=""
# 阿里云 AccessKey Secret
ALIYUN_SK=""
# DashScope API Key（阿里云百炼，用于语音识别）
DASHSCOPE_API_KEY=""

# ----- OSS 配置（可选，有默认值）-----
OSS_ENDPOINT="oss-cn-hangzhou.aliyuncs.com"
OSS_BUCKET="zwbssss"